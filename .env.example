# Raphael — Environment Variables
# cp .env.example .env && chmod 600 .env

# Database
DATABASE_URL=postgresql://creator@localhost:5432/raphael

# Redis (ARQ queue)
REDIS_URL=redis://localhost:6379

# Google AI Studio — Imagen 4 Fast ("нано банана 2")
# Get key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=
IMAGEN_MODEL=imagen-4.0-fast-generate-001
IMAGEN_ASPECT_RATIO=square
# Limits: ~500-1000 free images/day, 15 RPM | $0.02/image paid

# Ollama (Gemma — metadata only, runs locally)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b

# Shutterstock Contributor API
SS_CLIENT_ID=
SS_CLIENT_SECRET=
SS_USERNAME=

# Adobe Stock Contributor API
ADOBE_CLIENT_ID=
ADOBE_CLIENT_SECRET=

# Scheduler
PARSE_INTERVAL_HOURS=6
MAX_JOBS_PER_RUN=10
RETRY_MAX_ATTEMPTS=3
OUTPUT_KEEP_DAYS=14

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
