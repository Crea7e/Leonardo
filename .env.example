# Raphael — Environment Variables
# Скопируй в .env и заполни реальными значениями
# chmod 600 .env

# Database
DATABASE_URL=postgresql://creator@localhost:5432/raphael

# Redis (ARQ queue)
REDIS_URL=redis://localhost:6379

# ComfyUI
COMFYUI_URL=ws://localhost:8188
COMFYUI_OUTPUT_DIR=/home/creator/projects/Raphael/output

# Ollama (Gemma)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b

# Shutterstock Contributor API
SS_CLIENT_ID=
SS_CLIENT_SECRET=
SS_USERNAME=

# Adobe Stock Contributor API
ADOBE_CLIENT_ID=
ADOBE_CLIENT_SECRET=

# Scheduler
PARSE_INTERVAL_HOURS=6
MAX_JOBS_PER_RUN=10
RETRY_MAX_ATTEMPTS=3

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
