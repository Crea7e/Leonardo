# Raphael — Environment Variables
# cp .env.example .env && chmod 600 .env

# Database
DATABASE_URL=postgresql://creator@localhost:5432/raphael

# Redis (ARQ queue)
REDIS_URL=redis://localhost:6379

# Hugging Face — FLUX.1-schnell генерация + Real-ESRGAN 4x апскейл (бесплатно)
# Токен: https://huggingface.co/settings/tokens (read-only)
HF_TOKEN=

# Google AI Studio (платная альтернатива $0.02/фото)
GOOGLE_API_KEY=
IMAGEN_MODEL=gemini-2.5-flash-image

# Ollama (Gemma — metadata, локально)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b

# Shutterstock Contributor API
SS_CLIENT_ID=
SS_CLIENT_SECRET=
SS_USERNAME=

# Adobe Stock Contributor API
ADOBE_CLIENT_ID=
ADOBE_CLIENT_SECRET=

# Scheduler
PARSE_INTERVAL_HOURS=6
MAX_JOBS_PER_RUN=10
RETRY_MAX_ATTEMPTS=3
OUTPUT_KEEP_DAYS=14

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
